{
  "version": "1.0.0",
  "name": "扎克记忆系统配置",
  "description": "按周、月、年维度组织的记忆系统配置",
  "created": "2026-03-12T11:10:00.000Z",
  "updated": "2026-03-12T11:10:00.000Z",
  "author": "扎克",
  
  "directory_structure": {
    "daily": "每日记忆 - 保留最近7天",
    "weekly": "每周汇总 - 保留最近4周",
    "monthly": "每月汇总 - 保留最近12个月",
    "yearly": "年度汇总 - 永久保留",
    "categories": {
      "learning": "学习记录 - 学习进展、教程、知识总结",
      "skills": "技能掌握 - 技能学习、实践记录",
      "system": "系统状态 - 系统运行、监控、维护记录",
      "events": "重要事件 - 关键事件、里程碑"
    },
    "archive": "归档文件 - 历史文件归档"
  },
  
  "retention_policy": {
    "daily": {
      "days": 7,
      "description": "保留最近7天的每日记忆",
      "cleanup_schedule": "每日00:00自动清理"
    },
    "weekly": {
      "weeks": 4,
      "description": "保留最近4周的周汇总",
      "cleanup_schedule": "每周一00:00自动清理"
    },
    "monthly": {
      "months": 12,
      "description": "保留最近12个月的月汇总",
      "cleanup_schedule": "每月1日00:00自动清理"
    },
    "yearly": {
      "years": 10,
      "description": "永久保留年度汇总",
      "cleanup_schedule": "不自动清理"
    }
  },
  
  "summary_generation": {
    "weekly": {
      "schedule": "每周日23:59",
      "source": "daily/*.md",
      "template": "templates/weekly-summary.md"
    },
    "monthly": {
      "schedule": "每月最后一天23:59",
      "source": "weekly/*.md",
      "template": "templates/monthly-summary.md"
    },
    "yearly": {
      "schedule": "每年12月31日23:59",
      "source": "monthly/*.md",
      "template": "templates/yearly-summary.md"
    }
  },
  
  "file_naming_convention": {
    "daily": "YYYY-MM-DD.md",
    "weekly": "week-YYYY-WW.md",
    "monthly": "month-YYYY-MM.md",
    "yearly": "year-YYYY.md",
    "learning": "learning-*.md",
    "skills": "skill-*.md",
    "system": "system-*.md",
    "events": "event-*.md"
  },
  
  "maintenance": {
    "auto_cleanup": true,
    "auto_summary": true,
    "backup_before_cleanup": true,
    "notify_on_errors": true,
    "log_level": "info"
  },
  
  "current_status": {
    "daily_count": 8,
    "weekly_count": 1,
    "monthly_count": 1,
    "yearly_count": 1,
    "learning_count": 5,
    "skills_count": 0,
    "system_count": 3,
    "events_count": 0,
    "archive_count": 0,
    "last_organized": "2026-03-12T11:10:00.000Z",
    "health": "healthy"
  }
}