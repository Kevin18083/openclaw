#!/bin/bash
#===============================================================================
# Git Pre-Commit Hook - 杰克测试框架
# 版本：v1.0
# 用途：提交前自动运行快速检查，确保代码质量
#===============================================================================

set -e

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo ""
echo -e "${BLUE}════════════════════════════════════════${NC}"
echo -e "${BLUE}  Git Pre-Commit 检查${NC}"
echo -e "${BLUE}════════════════════════════════════════${NC}"
echo ""

# 获取脚本目录
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WORKSPACE_DIR="$(dirname "$SCRIPT_DIR")"

# 查找测试框架
if [ -f "$WORKSPACE_DIR/quick-check.sh" ]; then
    CHECK_SCRIPT="$WORKSPACE_DIR/quick-check.sh"
elif [ -f "$WORKSPACE_DIR/.test-framework/quick-check.sh" ]; then
    CHECK_SCRIPT="$WORKSPACE_DIR/.test-framework/quick-check.sh"
elif [ -f "./quick-check.sh" ]; then
    CHECK_SCRIPT="./quick-check.sh"
else
    echo -e "${YELLOW}⚠️  未找到 quick-check.sh，跳过检查${NC}"
    echo "可以通过以下命令安装："
    echo "  cp $WORKSPACE_DIR/.hooks/pre-commit .git/hooks/pre-commit"
    exit 0
fi

# 运行快速检查
echo "运行快速检查..."
echo ""

if bash "$CHECK_SCRIPT" . > /dev/null 2>&1; then
    echo -e "${GREEN}✅ Pre-Commit 检查通过${NC}"
    echo ""
    exit 0
else
    echo ""
    echo -e "${RED}❌ Pre-Commit 检查失败${NC}"
    echo ""
    echo "请修复以下问题后重新提交："
    echo "  1. 运行 bash quick-check.sh . 查看详细错误"
    echo "  2. 修复问题后重新提交"
    echo ""
    echo "如需跳过检查（不推荐）："
    echo "  git commit --no-verify"
    echo ""
    exit 1
fi
