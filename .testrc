#===============================================================================
# 杰克测试框架 - 配置文件
# 版本：v2.0
# 用途：自定义测试框架的各项配置
#===============================================================================

#-------------------------------------------------------------------------------
# 测试配置
#-------------------------------------------------------------------------------

# 初步测试最大重试轮数
MAX_RETRIES=5

# 复查验证轮数（连续通过次数）
VERIFY_RETRIES=3

# 日志目录
LOG_DIR="./test-logs"

#-------------------------------------------------------------------------------
# 决策树配置
#-------------------------------------------------------------------------------

# 权重配置（总和应为 100）
WEIGHT_BASE_TEST=30      # 基础测试权重
WEIGHT_SECURITY=30       # 安全检查权重
WEIGHT_CODE_QUALITY=15   # 代码质量权重
WEIGHT_UNIT_TEST=15      # 单元测试权重
WEIGHT_BUILD=10          # 构建检查权重

# 通过线配置
THRESHOLD_BASE_TEST=100  # 基础测试必须 100% 通过
THRESHOLD_SECURITY=0     # 安全必须 0 问题
THRESHOLD_CODE_QUALITY=90  # 代码质量≥90 分
THRESHOLD_UNIT_TEST=90     # 单元测试≥90%
THRESHOLD_BUILD=100      # 构建必须成功

# 总分通过线
PASSING_SCORE=80         # 总分≥80 分可以实装

#-------------------------------------------------------------------------------
# 排除目录配置
#-------------------------------------------------------------------------------

# 排除的目录（空格分隔）
EXCLUDE_DIRS="node_modules .git dist build coverage venv __pycache__ .next .nuxt output"

# 排除的文件模式
EXCLUDE_FILES="*.log *.tmp *.bak *.swp *.swo"

#-------------------------------------------------------------------------------
# 代码质量检查配置
#-------------------------------------------------------------------------------

# 大文件行数阈值
LARGE_FILE_LINES=800

# 待处理标记检测
CHECK_TODOS=true         # 检测 TODO/FIXME/HACK
CHECK_DEBUGS=true        # 检测 console.log/debugger
CHECK_SECRETS=true       # 检测硬编码密钥
CHECK_EMPTY_CATCH=true   # 检测空 catch 块
CHECK_NESTED_LOOPS=true  # 检测嵌套循环

# 扣分配置
PENALTY_TODO=3           # 每个 TODO 扣 3 分
PENALTY_DEBUG=8          # 每个调试语句扣 8 分
PENALTY_LARGE_FILE=10    # 每个大文件扣 10 分
PENALTY_SECRET=15        # 每个硬编码密钥扣 15 分
PENALTY_EMPTY_CATCH=5    # 每个空 catch 扣 5 分
PENALTY_NESTED_LOOP=5    # 每个嵌套循环扣 5 分

#-------------------------------------------------------------------------------
# 安全检查配置
#-------------------------------------------------------------------------------

# 敏感文件检测
CHECK_SENSITIVE_FILES=true
SENSITIVE_FILE_PATTERNS=".env *.pem *.key credentials* *.secret"

# SQL 注入检测
CHECK_SQL_INJECTION=true

# eval 执行检测
CHECK_EVAL_USAGE=true

# 路径遍历检测
CHECK_PATH_TRAVERSAL=true

#-------------------------------------------------------------------------------
# 性能检查配置
#-------------------------------------------------------------------------------

# 嵌套循环检测
CHECK_NESTED_LOOPS_PERF=true

# 依赖包大小阈值（MB）
MAX_NODE_MODULES_SIZE=500

# 内存泄漏检测
CHECK_MEMORY_LEAK=true

#-------------------------------------------------------------------------------
# 单元测试配置
#-------------------------------------------------------------------------------

# 覆盖率要求（百分比）
REQUIRED_COVERAGE=90

# 测试超时时间（秒）
TEST_TIMEOUT=120

# 自动检测测试框架
AUTO_DETECT_TEST_FRAMEWORK=true

#-------------------------------------------------------------------------------
# 构建检查配置
#-------------------------------------------------------------------------------

# 构建超时时间（秒）
BUILD_TIMEOUT=180

# 构建后运行测试
RUN_POST_BUILD_TEST=true

# 构建产物目录
BUILD_OUTPUT_DIRS="dist build lib output"

#-------------------------------------------------------------------------------
# 记忆库配置
#-------------------------------------------------------------------------------

# 记忆库目录
MEMORY_DIR="./memory"

# 错误记忆库文件
ERROR_MEMORY="$MEMORY_DIR/error-memory.md"

# 成功案例记忆库文件
SUCCESS_MEMORY="$MEMORY_DIR/success-memory.md"

# 自动记录错误
AUTO_RECORD_ERROR=true

# 自动记录成功
AUTO_RECORD_SUCCESS=true

#-------------------------------------------------------------------------------
# 颜色配置
#-------------------------------------------------------------------------------

# 启用颜色输出
USE_COLORS=true

# 颜色定义
COLOR_RED='\033[0;31m'
COLOR_GREEN='\033[0;32m'
COLOR_YELLOW='\033[1;33m'
COLOR_BLUE='\033[0;34m'
COLOR_CYAN='\033[0;36m'
COLOR_MAGENTA='\033[0;35m'
COLOR_NC='\033[0m'

#-------------------------------------------------------------------------------
# 其他配置
#-------------------------------------------------------------------------------

# 详细日志模式
VERBOSE_MODE=false

# 静默模式
SILENT_MODE=false

# 失败后立即停止
STOP_ON_FAILURE=false

# 生成 HTML 报告
GENERATE_HTML_REPORT=false

# 生成 Markdown 报告
GENERATE_MD_REPORT=true
